// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // only via Admin SDK or trusted code
    }

    // All authenticated users can read/write appointments, patients, recalls
    match /appointments/{doc} {
      allow read, write: if request.auth != null;
    }
    match /patients/{doc} {
      allow read, write: if request.auth != null;
    }
    match /recalls/{doc} {
      allow read, write: if request.auth != null;
    }

    // Settings (procedures, dentists, rooms) — read for all, write for admin only
    match /procedures/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /dentists/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /rooms/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
